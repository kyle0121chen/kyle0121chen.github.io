diff --git a/web2/style.css b/web2/style.css
index 6940e47..6b763a2 100644
--- a/web2/style.css
+++ b/web2/style.css
@@ -251,9 +251,66 @@ a:hover {
   text-shadow: none;
 }
 
+/* Hero Carousel */
+.hero-carousel {
+  position: relative;
+  width: 100%;
+  height: 450px;
+  overflow: hidden;
+  margin-bottom: 3rem;
+  border: 1px solid var(--border-color);
+  background-color: var(--bg-secondary);
+  border-radius: 2px;
+}
+
+.carousel-slide {
+  position: absolute;
+  top: 0;
+  left: 0;
+  width: 100%;
+  height: 100%;
+  opacity: 0;
+  transition: opacity 2s ease-in-out;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+}
+
+.carousel-slide.active {
+  opacity: 1;
+  z-index: 1;
+}
+
+.carousel-slide img {
+  width: 100%;
+  height: 100%;
+  object-fit: cover;
+  filter: grayscale(20%) contrast(90%);
+  transition: filter 0.5s ease;
+}
+
+.carousel-slide:hover img {
+  filter: grayscale(0%) contrast(100%);
+}
+
+.carousel-caption {
+  position: absolute;
+  bottom: 1.5rem;
+  right: 1.5rem;
+  background: rgba(42, 39, 35, 0.7);
+  color: #fff;
+  padding: 0.5rem 1rem;
+  font-size: 0.7rem;
+  text-transform: uppercase;
+  letter-spacing: 2px;
+  backdrop-filter: blur(5px);
+  border: 1px solid rgba(255, 255, 255, 0.1);
+  z-index: 2;
+}
+
 /* Main Content Styles */
 .content {
-  padding: 4rem 3%;
+  padding: 4rem 3% 60vh; /* Added 60vh bottom padding */
   width: 100%;
   max-width: 1100px;
 }
